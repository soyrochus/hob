# Optional explicit provider selection: openai | azure
# If unset, provider auto-detection order is:
# 1) OPENAI_API_KEY
# 2) AZURE_OPENAI_ENDPOINT
LLM_PROVIDER=openai

# Direct OpenAI configuration
OPENAI_API_KEY=your_api_key
# Optional: enables hosted file_search in defaultAssistant supervisor delegation
NEXT_PUBLIC_OPENAI_VECTOR_STORE_ID=

# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview
AZURE_OPENAI_RESPONSES_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-4o-mini
